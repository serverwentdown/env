// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  // Disable collaboration and chat features
  "collaboration_panel": {
    "button": false,
  },
  // Configure AI features
  "agent_servers": {
    "cursor": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "sweep": {
      "privacy_mode": true,
    },
    "open_ai_compatible_api": {
      "api_url": "https://localhost",
    },
    "codestral": {
      "api_url": "https://localhost",
    },
    "provider": "none",
  },
  "agent": {
    "notify_when_agent_waiting": "all_screens",
    "dock": "left",
    "play_sound_when_agent_done": true,
    "default_profile": "write",
    "single_file_review": false,
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
  },
  "language_models": {
    "anthropic": {
      "api_url": "https://localhost",
      "available_models": [],
    },
    "google": {
      "api_url": "https://localhost",
      "available_models": [],
    },
    "openai": {
      "api_url": "https://localhost",
      "available_models": [],
    },
    "lmstudio": {
      "api_url": "https://localhost",
      "available_models": [],
    },
    "deepseek": {
      "api_url": "https://localhost",
      "available_models": [],
    },
    "mistral": {
      "api_url": "https://localhost",
      "available_models": [],
    },
    "bedrock": {
      "endpoint_url": "https://localhost",
      "available_models": [],
    },
    "ollama": {
      "api_url": "https://localhost",
      "available_models": [],
    },
    "open_router": {
      "api_url": "https://localhost",
      "available_models": [],
    },
    "vercel": {
      "api_url": "https://localhost",
      "available_models": [],
    },
    "x_ai": {
      "api_url": "https://localhost",
      "available_models": [],
    },
    "zed.dev": {
      "available_models": [],
    },
  },
  // Layout
  "git_panel": {
    "tree_view": true,
    "dock": "right",
  },
  "project_panel": {
    "entry_spacing": "comfortable",
    "default_width": 240.0,
    "dock": "right",
  },
  // Appearance
  "theme": {
    "mode": "system",
    "dark": "Zed Legacy: Solarized Dark",
    "light": "Zed Legacy: Solarized Light",
  },
  "ui_font_size": 14,
  "buffer_font_size": 13,
  "buffer_font_family": "Fira Code",
  // Editor
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "wrap_guides": [80, 110],
  "show_completions_on_input": true,
  "languages": {
    "Nix": {
      "language_servers": ["nixd"],
    },
  },
  // Security
  "redact_private_values": true,
  // Extensions
  "auto_install_extensions": {
    "zed-legacy-themes": true,
    "docker-compose": true,
    "dockerfile": true,
    "env": true,
    "git-firefly": true,
    "golangci-lint": true,
    "html": true,
    "log": true,
    "lua": true,
    "make": true,
    "nix": true,
    "proto": true,
    "rainbow-csv": true,
    "sql": true,
    "terraform": true,
    "toml": true,
  },
}
